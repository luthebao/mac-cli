{
  "folders": [
    {
      "name": "mac-cli",
      "path": "."
    }
  ],
  "settings": {
    "files.associations": {
      "*.odin": "odin"
    },
    "files.exclude": {
      "**/.DS_Store": true
    },
    "editor.insertSpaces": false,
    "editor.tabSize": 4,
    "[odin]": {
      "editor.insertSpaces": false,
      "editor.tabSize": 4,
      "editor.detectIndentation": false
    },
    "terminal.integrated.env.osx": {
      "PATH": "/opt/homebrew/bin:${env:PATH}"
    }
  }
}