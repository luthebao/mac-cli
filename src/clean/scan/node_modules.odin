package clean_scan

import "base:runtime"
import "core:os"
import "core:strings"
import "core:time"

import "mc:clean/types"
import "mc:fsx"

NM_AGE_THRESHOLD_DAYS :: 90

node_modules_scan :: proc(_: types.ScannerOptions, allocator: runtime.Allocator) -> types.ScanResult {
	cat := types.category_of(.Node_Modules)
	items := make([dynamic]types.CleanableItem, 0, 32, allocator)
	total: i64 = 0

	home := fsx.expand("~", context.temp_allocator)
	now := time.now()
	threshold := time.Duration(NM_AGE_THRESHOLD_DAYS) * 24 * time.Hour

	find_node_modules(&items, &total, home, 0, now, threshold, allocator)

	return types.ScanResult{
		category   = cat,
		items      = items[:],
		total_size = total,
	}
}

node_modules_clean :: proc(items: []types.CleanableItem, dry_run: bool, allocator: runtime.Allocator) -> types.CleanResult {
	return clean_items(types.category_of(.Node_Modules), items, dry_run, allocator)
}

@(private)
find_node_modules :: proc(
	out: ^[dynamic]types.CleanableItem,
	total: ^i64,
	dir: string,
	depth: int,
	now: time.Time,
	threshold: time.Duration,
	allocator: runtime.Allocator,
) {
	if depth > 5 {
		return
	}
	entries, err := os.read_directory_by_path(dir, -1, context.temp_allocator)
	if err != nil {
		return
	}
	for e in entries {
		if e.type != .Directory {
			continue
		}
		// Skip common heavy roots that aren't useful to scan.
		if strings.has_prefix(e.name, ".") || e.name == "Library" || e.name == "Applications" {
			continue
		}
		if e.name == "node_modules" {
			age := time.diff(e.modification_time, now)
			if age < threshold {
				continue
			}
			size, _ := fsx.dir_size(e.fullpath)
			if size <= 0 {
				continue
			}
			append(out, types.CleanableItem{
				path              = strings.clone(e.fullpath, allocator),
				name              = strings.clone(e.fullpath, allocator),
				size              = size,
				is_directory      = true,
				modification_time = e.modification_time,
			})
			total^ += size
			continue // don't recurse into a node_modules
		}
		find_node_modules(out, total, e.fullpath, depth + 1, now, threshold, allocator)
	}
}
